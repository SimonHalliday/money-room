# Copy this file to ".env" and fill in your own values.
# The two VITE_ ones come from your Supabase project (Settings -> API).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# This one is ONLY used by the Netlify function (server-side, never in the browser).
# For local testing with `netlify dev`, put it here too. In production set it in
# Netlify -> Site settings -> Environment variables instead.
ANTHROPIC_API_KEY=your-anthropic-api-key
